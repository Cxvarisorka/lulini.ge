{
  "cli": {
    "version": ">= 5.2.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.gotours.ge/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://api.gotours.ge",
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "REMOVED_SECRET"
      },
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.gotours.ge/api",
        "EXPO_PUBLIC_SOCKET_URL": "https://api.gotours.ge",
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "REMOVED_SECRET"
      },
      "ios": {
        "resourceClass": "m-medium"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
