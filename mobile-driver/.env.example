# ── API URLs ──────────────────────────────────────────────
EXPO_PUBLIC_API_URL=https://api.lulini.ge/api
EXPO_PUBLIC_SOCKET_URL=https://api.lulini.ge

# ── Mapbox ───────────────────────────────────────────────
# Public access token (pk.*) — read at runtime by Mapbox.setAccessToken
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your_public_token_here
# Secret download token (sk.*) — used by the @rnmapbox/maps Expo plugin during prebuild
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=sk.your_download_token_here

# ── Sentry ───────────────────────────────────────────────
SENTRY_DSN=your_sentry_dsn_here
