# Server
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/lulini

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Client URL (for OAuth redirects)
CLIENT_URL=http://localhost:5173

# Cookie domain (set in production to share cookies across subdomains)
# COOKIE_DOMAIN=.lulini.ge

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
GOOGLE_ANDROID_CLIENT_ID=your_android_oauth_client_id
GOOGLE_IOS_CLIENT_ID=your_ios_oauth_client_id

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback

# SMSOffice.ge (Phone Verification)
SMS_API=your_smsoffice_api_key

# Google Maps API (server-side proxy for Directions, Distance Matrix, Roads, Geocoding)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Redis (optional — enables horizontal scaling, shared caching across instances)
# REDIS_URL=redis://localhost:6379

# Sentry Error Tracking (optional)
# SENTRY_DSN=your_sentry_dsn

# Email (SMTP)
SMTP_HOST=mail.hostedemail.com
SMTP_PORT=465
SMTP_USER=info@lulini.ge
SMTP_PASS=your_email_password
SMTP_FROM=info@lulini.ge

# ── Location Optimization Feature Flags ──
# All default to OFF (false). Enable incrementally during rollout.
# FF_GEOCODING_CACHE=true          # Phase 1.3: Cache geocoding results in Redis (24h TTL)
# FF_CANONICAL_LOCATIONS=true      # Phase 1.4: Store locations in normalized Location collection
# FF_REDIS_DRIVER_LOCATIONS=true   # Phase 3: Write driver positions to Redis GEO (dual-write)
# FF_REDIS_NEARBY_QUERY=true       # Phase 3: Read nearby drivers from Redis GEO instead of MongoDB
# FF_ETA_DISPATCH=true             # Phase 8: ETA-based sequential driver offers instead of broadcast
# FF_PICKUP_ROAD_SNAP=true         # Phase 4: Snap pickup coords to nearest road after ride creation
# FF_LOCATION_RETENTION=true       # Phase 7: Strip routePoints from rides older than retention period

# Location Retention Settings
# ROUTE_POINTS_RETENTION_DAYS=90   # Days before routePoints are stripped (default: 90)

# Nominatim Settings (optional — defaults work for public instance)
# NOMINATIM_URL=https://nominatim.openstreetmap.org
# NOMINATIM_USER_AGENT=Lulini/1.0 (ride-hailing; contact@lulini.ge)
