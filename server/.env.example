# Server
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/gotours

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Client URL (for OAuth redirects)
CLIENT_URL=http://localhost:5173

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
GOOGLE_ANDROID_CLIENT_ID=your_android_oauth_client_id
GOOGLE_IOS_CLIENT_ID=your_ios_oauth_client_id

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback

# Twilio Verify (Phone Verification)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid

# Google Maps API (server-side proxy for Directions, Distance Matrix, Roads, Geocoding)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
