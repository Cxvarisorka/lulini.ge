# ── API URLs ──────────────────────────────────────────────
# .env          → development (used by `expo start`)
# .env.production → production (used by `npm run build:android`)

EXPO_PUBLIC_API_URL=http://192.168.100.3:3000/api
EXPO_PUBLIC_SOCKET_URL=http://192.168.100.3:3000

# ── Google ────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id_here
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_client_id_here

# ── Sentry ────────────────────────────────────────────────
EXPO_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
