# Google Maps API Key (same as website VITE_GOOGLE_MAPS_API_KEY)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Mapbox Access Token (for better address geocoding - free tier: 100k requests/month)
# Get your token at: https://account.mapbox.com/
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# EAS Project ID (get from expo.dev after running `eas init`)
EAS_PROJECT_ID=your_eas_project_id_here
